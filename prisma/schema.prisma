  expiresAt          DateTime
  isActive           Boolean   @default(true)

  // Relations
  simulatedUser      User      @relation("SimulatedUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  adminCreator       User      @relation("AdminCreator", fields: [realAdminId], references: [id], onDelete: Cascade)
  sandboxes          SimulationSandbox[]

  @@index([simulationToken])
  @@map("simulation_sessions")
}

model SimulationSandbox {
  id         String            @id @default(uuid()) @db.Uuid
  sessionId  String            @db.Uuid
  entityType String
  entityId   String?
