  studentId    String           @db.Uuid
  attachmentId String           @db.Uuid
  downloadedAt DateTime         @default(now())

  student      User             @relation("StudentDownload", fields: [studentId], references: [id], onDelete: Cascade)
  attachment   LessonAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([attachmentId])
  @@map("download_histories")
}

model Leaderboard {
  id          String             @id @default(uuid()) @db.Uuid
  courseId    String             @db.Uuid
  displayMode String             @default("REAL_NAMES") // REAL_NAMES, STUDENT_CODE, ANONYMOUS
  isHidden    Boolean            @default(false)
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt

  course      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  entries     LeaderboardEntry[]

  @@index([courseId])
  @@map("leaderboards")
}

model LeaderboardEntry {
  id               String      @id @default(uuid()) @db.Uuid
  leaderboardId    String      @db.Uuid
  studentId        String      @db.Uuid
  points           Decimal     @db.Decimal(8, 2)
  rank             Int
  medal            String?     // GOLD, SILVER, BRONZE
  examsPoints      Decimal     @db.Decimal(8, 2) @default(0.00)
  courseCompPoints Decimal     @db.Decimal(8, 2) @default(0.00)
  assignmentsPoints Decimal    @db.Decimal(8, 2) @default(0.00)
  attendancePoints  Decimal    @db.Decimal(8, 2) @default(0.00)
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  leaderboard      Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  student          User        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([leaderboardId])
  @@index([studentId])
  @@map("leaderboard_entries")
}

model CouponCode {
