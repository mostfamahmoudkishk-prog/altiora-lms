datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
  SUPER_ADMIN
}

enum LoginStatus {
  SUCCESS
  FAILED
}

enum TicketStatus {
  OPEN
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// ==========================================
// AUTHENTICATION & USERS
// ==========================================

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  passwordHash String
  role         UserRole      @default(STUDENT)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  deleted_at   DateTime?

  profile                Profile?
  sessions               Session[]
  devices                Device[]
  loginHistories         LoginHistory[]
  courseInstructors      CourseInstructor[]
  reviews                CourseReview[]
  enrollments            Enrollment[]
  progress               StudentProgress[]
  watchHistories         WatchHistory[]
  continueWatching       ContinueWatching[]
  timeline               ActivityTimeline[]
  videoNotes             VideoNote[]
  savedNotes             SavedNote[]
  wishlist               Wishlist[]
  recentViews            RecentlyViewed[]
  downloadHistory        DownloadedFileHistory[]
  attempts               ExamAttempt[]
  violations             ExamViolation[]
  antiCheatEvents        AntiCheatEvent[]
  orders                 Order[]
  certificates           Certificate[]
  comments               Comment[]
  discussions            Discussion[]
  answers                AnswerDiscussion[]
  notifications          Notification[]
  emailNotifications     EmailNotification[]
  pushNotifications      PushNotification[]
  tickets                Ticket[]
  replies                Reply[]
  complaints             Complaint[]
  watchTimeAnalytics     WatchTimeAnalytics[]
  auditLogs              AuditLog[]
  securityEvents         SecurityEvent[]
  suspiciousActivities   SuspiciousActivity[]
  accessCodesCreated     StudentAccessCode[]     @relation("AccessCodeCreator")
  accessCodesClaimed     StudentAccessCode[]     @relation("AccessCodeClaimant")
  initiatedBackups       BackupLog[]

  userSessions           UserSession[]
  userDevices            UserDevice[]
  userSecurityEvents     UserSecurityEvent[]
  userExamViolations     UserExamViolation[]
  userWatchProgresses    UserWatchProgress[]
  userVideoNotes         UserVideoNote[]
  userDownloadHistories  UserDownloadHistory[]
  userActivityTimelines  UserActivityTimeline[]
  activityLogs           ActivityLog[]
  studentCode            StudentCode?
  maintenanceLogs        MaintenanceLog[]
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  watchTimeStats         WatchTimeStats[]
  studentActivityStats   StudentActivityStats?
  canCustomizeBranding   Boolean @default(false)
  deviceLimit            Int @default(1)
  isBanned               Boolean @default(false)
  averageRating          Float @default(5.0)
  reviewsCount           Int @default(0)
  premiumReputationEnabled Boolean @default(false)
  theme                    String? @default("system")
  themePreset              String? @default("luxury")

  // Reviews relations
  teacherReviews         TeacherReview[] @relation("TeacherReviews")
  studentReviews         TeacherReview[] @relation("StudentReviews")
  reportsCreated         ReviewReport[] @relation("ReporterUser")


  // Phase 4 - 8 relations
  revenueSettings        RevenueSettings[]
  revenueTransactions    RevenueTransaction[]    @relation("TeacherRevenue")
  studentTransactions    RevenueTransaction[]    @relation("StudentRevenue")
  uploadedAttachments    LessonAttachment[]      @relation("AttachmentUploader")
  attachmentDownloads    DownloadHistory[]       @relation("StudentDownload")
  leaderboardEntries     LeaderboardEntry[]
  couponsCreated         CouponCode[]            @relation("TeacherCoupon")
  enrollmentCodesCreated EnrollmentCode[]        @relation("CreatorEnrollmentCode")
  enrollmentCodesUsed    EnrollmentCode[]        @relation("UserEnrollmentCode")

  // Public Profile & Branding relations
  instructorBranding     InstructorBranding?
  featuredInstructor     FeaturedInstructor?     @relation("FeaturedInstructorLink")
  createdFeaturedInstructors FeaturedInstructor[] @relation("FeaturedCreator")

  liveSessions           LiveSession[]
  liveParticipants       LiveParticipant[]
  liveAttendances        LiveAttendance[]
  liveChatMessages       LiveChatMessage[]
  liveRaisedHands        LiveRaisedHand[]
  liveReactions          LiveReaction[]

  sentMessages           Message[]          @relation("SentMessages")
  receivedMessages       MessageRecipient[] @relation("ReceivedMessages")

  // Simulation relations
  simulatedSessions      SimulationSession[]   @relation("SimulatedUser")
  createdSimulations     SimulationSession[]   @relation("AdminCreator")
  adminSimulationLogs    SimulationAuditLog[]  @relation("AuditAdmin")
  targetSimulationLogs   SimulationAuditLog[]  @relation("AuditTargetUser")

  reviewedExams          ExamAttempt[]         @relation("ExamReviewer")
  essayReviewLogs        EssayReviewLog[]
  examPublishLogs        ExamPublishLog[]
  notificationReadLogs   NotificationReadLog[]
  feedbackTemplates      TeacherFeedbackTemplate[]

  @@index([role])
}

model Profile {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @db.Uuid
  name        String
  avatarUrl   String?
  biography   String?   @db.Text
  credentials String?   @db.Text
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  token      String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Device {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  deviceFingerprint String
  userAgent         String?
  ipAddress         String?
  lastActive        DateTime  @default(now())
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceFingerprint])
}

model LoginHistory {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  ipAddress     String?
  userAgent     String?
  status        LoginStatus
  failureReason String?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  deleted_at    DateTime?

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// COURSES
// ==========================================

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?   @db.Text
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  courses     Course[]
}

model Course {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  description String?   @db.Text
  price       Decimal   @db.Decimal(10, 2)
  coverImage  String?
  categoryId  String    @db.Uuid
  isArchived  Boolean   @default(false)
  isFeatured  Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  category          Category           @relation(fields: [categoryId], references: [id])
  instructors       CourseInstructor[]
  modules           Module[]
  reviews           CourseReview[]
  enrollments       Enrollment[]
  progress          StudentProgress[]
  wishlist          Wishlist[]
  recentViews       RecentlyViewed[]
  accessCodes       StudentAccessCode[]
  exams             Exam[]
  discussions       Discussion[]
  certificates      Certificate[]
  continueWatching  ContinueWatching[]
  watchTimeAnalytic WatchTimeAnalytics[]
  featuredCourse    FeaturedCourse?
  watchTimeStats    WatchTimeStats[]
  completionStats   CourseCompletionStats?

  // Phase 4 - 8 relations
  revenueTransactions  RevenueTransaction[]
  leaderboards         Leaderboard[]
  coupons              CouponCode[]
  enrollmentCodes      EnrollmentCode[]      @relation("CourseEnrollmentCode")
  liveSessions         LiveSession[]

  @@index([categoryId])
  @@index([isFeatured])
  @@index([isArchived])
}

model CourseInstructor {
  id             String    @id @default(uuid()) @db.Uuid
  courseId       String    @db.Uuid
  instructorId   String    @db.Uuid
  commissionRate Decimal   @db.Decimal(5, 2)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  course         Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor     User      @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([courseId, instructorId])
  @@index([instructorId])
}

model Module {
  id         String    @id @default(uuid()) @db.Uuid
  courseId   String    @db.Uuid
  title      String
  sortOrder  Int       @default(0)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons    Lesson[]

  @@index([courseId])
}

model Lesson {
  id         String    @id @default(uuid()) @db.Uuid
  moduleId   String    @db.Uuid
  title      String
  sortOrder  Int       @default(0)
  isPreview  Boolean   @default(false)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  module           Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attachments      Attachment[]
  pdfFiles         PdfFile[]
  videoMetadata    VideoMetadata?
  progress         StudentProgress[]
  savedNotes       SavedNote[]
  exams            Exam[]
  comments         Comment[]
  continueWatching ContinueWatching[]
  videos           Video[]
  userWatchProgresses UserWatchProgress[]
  userVideoNotes   UserVideoNote[]
  lessonAttachments LessonAttachment[]


  @@index([moduleId])
}

model Attachment {
  id         String    @id @default(uuid()) @db.Uuid
  lessonId   String    @db.Uuid
  title      String
  fileUrl    String
  fileType   String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  lesson     Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model PdfFile {
  id         String    @id @default(uuid()) @db.Uuid
  lessonId   String    @db.Uuid
  title      String
  fileUrl    String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  lesson     Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model VideoMetadata {
  id           String    @id @default(uuid()) @db.Uuid
  lessonId     String    @unique @db.Uuid
  videoUrl     String
  duration     Int       @default(0) // seconds
  size         BigInt    @default(0) // bytes
  videoId      String?
  thumbnailUrl String?
  status       String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  lesson     Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model CourseReview {
  id         String    @id @default(uuid()) @db.Uuid
  courseId   String    @db.Uuid
  studentId  String    @db.Uuid
  rating     Int       @default(5)
  comment    String?   @db.Text
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([studentId])
}

// ==========================================
// VIDEOS
// ==========================================

model Video {
  id         String    @id @default(uuid()) @db.Uuid
  lessonId   String    @db.Uuid
  url        String
  duration   Int       @default(0)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  lesson       Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  watchHistory WatchHistory[]
  videoNotes   VideoNote[]

  @@index([lessonId])
}

model WatchHistory {
  id             String    @id @default(uuid()) @db.Uuid
  studentId      String    @db.Uuid
  videoId        String    @db.Uuid
  watchTime      Int       @default(0) // seconds
  completionRate Decimal   @default(0.00) @db.Decimal(5, 2)
  lastViewed     DateTime  @default(now())
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  student        User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  video          Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([studentId, videoId])
  @@index([videoId])
}

model ContinueWatching {
  id            String    @id @default(uuid()) @db.Uuid
  studentId     String    @db.Uuid
  courseId      String    @db.Uuid
  lessonId      String    @db.Uuid
  currentSecond Int       @default(0)
  playbackSpeed Decimal   @default(1.00) @db.Decimal(3, 2)
  lastViewed    DateTime  @default(now())
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  student       User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson        Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId])
}

model VideoNote {
  id         String    @id @default(uuid()) @db.Uuid
  studentId  String    @db.Uuid
  videoId    String    @db.Uuid
  second     Int
  content    String    @db.Text
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  student    User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  video      Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([videoId])
}

// ==========================================
// STUDENTS
// ==========================================

model Enrollment {
  id             String    @id @default(uuid()) @db.Uuid
  studentId      String    @db.Uuid
  courseId       String    @db.Uuid
  completionRate Decimal   @default(0.00) @db.Decimal(5, 2)
  watchTime      Int       @default(0)
  lastActivity   DateTime  @default(now())
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  student        User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course         Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([courseId])
}

model StudentProgress {
  id          String    @id @default(uuid()) @db.Uuid
  studentId   String    @db.Uuid
  courseId    String    @db.Uuid
  lessonId    String    @db.Uuid
  completed   Boolean   @default(false)
  completedAt DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId, courseId])
}

model ActivityTimeline {
  id           String    @id @default(uuid()) @db.Uuid
  studentId    String    @db.Uuid
  activityType String
  metadata     Json?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  student      User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model SavedNote {
  id         String    @id @default(uuid()) @db.Uuid
  studentId  String    @db.Uuid
  lessonId   String    @db.Uuid
  content    String    @db.Text
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  student    User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson     Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([lessonId])
}

model Wishlist {
  id         String    @id @default(uuid()) @db.Uuid
  studentId  String    @db.Uuid
  courseId   String    @db.Uuid
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  student    User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
}

model RecentlyViewed {
  id         String    @id @default(uuid()) @db.Uuid
  studentId  String    @db.Uuid
  courseId   String    @db.Uuid
  viewedAt   DateTime  @default(now())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  student    User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
}

model DownloadedFileHistory {
  id           String    @id @default(uuid()) @db.Uuid
  studentId    String    @db.Uuid
  fileUrl      String
  fileName     String
  downloadedAt DateTime  @default(now())
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  student      User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ==========================================
// ACCESS CODES
// ==========================================

model StudentAccessCode {
  id           String    @id @default(uuid()) @db.Uuid
  code         String    @unique
  courseId     String    @db.Uuid
  studentId    String?   @db.Uuid
  createdBy    String    @db.Uuid
  maxUsage     Int       @default(1)
  currentUsage Int       @default(0)
  expiresAt    DateTime?
  disabled     Boolean   @default(false)
  usedAt       DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  creator      User      @relation("AccessCodeCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  claimant     User?     @relation("AccessCodeClaimant", fields: [studentId], references: [id])

  @@index([courseId])
  @@index([studentId])
}

// ==========================================
// EXAMS & ANTI-CHEAT
// ==========================================

model Exam {
  id            String    @id @default(uuid()) @db.Uuid
  lessonId      String?   @db.Uuid
  courseId      String    @db.Uuid
  title         String
  durationLimit Int       @default(0) // minutes, 0 means no limit
  passScore     Decimal   @default(50.00) @db.Decimal(5, 2)
  maxAttempts   Int       @default(1)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?
  description   String?
  published     Boolean   @default(false)
  isPublished   Boolean   @default(false)
  shuffleQuestions Boolean @default(false)
  shuffleChoices   Boolean @default(false)
  useRandomSubset  Boolean @default(false)
  subsetQuestionCount Int   @default(0)
  showResults      Boolean @default(true)

  lesson          Lesson?          @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions       Question[]
  attempts        ExamAttempt[]
  antiCheatEvents AntiCheatEvent[]
  userExamViolations UserExamViolation[]
  sections        ExamSection[]
  versions        ExamVersion[]

  @@index([courseId])
  @@index([lessonId])
}

model ExamVersion {
  id                String   @id @default(uuid()) @db.Uuid
  examId            String   @db.Uuid
  version           Int
  snapshot          Json
  created_at        DateTime @default(now())
  changeDescription String?  @db.Text

  exam              Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model ExamSection {
  id          String     @id @default(uuid()) @db.Uuid
  examId      String     @db.Uuid
  name        String
  description String?    @db.Text
  mark        Decimal?   @db.Decimal(5, 2)
  duration    Int?       // minutes, optional
  order       Int        @default(0)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  deleted_at  DateTime?

  exam        Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions   Question[]

  @@index([examId])
}

enum QuestionDifficulty {
  VERY_EASY
  EASY
  MEDIUM
  HARD
  VERY_HARD
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
}

model Question {
  id             String              @id @default(uuid()) @db.Uuid
  examId         String              @db.Uuid
  text           String              @db.Text
  type           String              // MCQ, TRUE_FALSE, ORDERING
  sortOrder      Int                 @default(0)
  points         Int                 @default(1)
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt
  deleted_at     DateTime?

  // Extended fields for advanced exams
  qType          QuestionType?       @default(MULTIPLE_CHOICE)
  difficulty     QuestionDifficulty? @default(MEDIUM)
  explanation    String?             @db.Text
  questionText   String?             @db.Text
  mark           Int?                @default(1)
  order          Int?                @default(0)
  imageUrl       String?
  pdfUrl         String?
  isImported     Boolean             @default(false)
  sectionId      String?             @db.Uuid

  exam           Exam                @relation(fields: [examId], references: [id], onDelete: Cascade)
  section        ExamSection?        @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  choices        Choice[]
  essayAnswers   EssayAnswer[]
  attemptAnswers ExamAttemptAnswer[]

  @@index([examId])
  @@index([sectionId])
}

model Choice {
  id         String    @id @default(uuid()) @db.Uuid
  questionId String    @db.Uuid
  text       String
  isCorrect  Boolean   @default(false)
  sortOrder  Int       @default(0)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  // Extended fields
  choiceText String?   @db.Text

  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model ExamAttempt {
  id          String    @id @default(uuid()) @db.Uuid
  examId      String    @db.Uuid
  studentId   String    @db.Uuid
  score       Decimal   @default(0.00) @db.Decimal(5, 2)
  passed      Boolean   @default(false)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  isPendingManualReview Boolean   @default(false)
  manualScore          Decimal?  @db.Decimal(5, 2)
  teacherFeedback      String?   @db.Text
  publishedAt          DateTime?
  isPublished          Boolean   @default(false)
  reviewedById         String?   @db.Uuid
  reviewedAt           DateTime?

  exam        Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reviewedBy  User?           @relation("ExamReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  violations  ExamViolation[]
  essayAnswers   EssayAnswer[]
  attemptAnswers ExamAttemptAnswer[]
  essayReviewLogs EssayReviewLog[]
  examPublishLogs ExamPublishLog[]
  aiRecommendation AIStudyRecommendation?

  @@index([examId])
  @@index([studentId])
  @@index([reviewedById])
}

model ExamViolation {
  id         String    @id @default(uuid()) @db.Uuid
  attemptId  String    @db.Uuid
  studentId  String    @db.Uuid
  type       String    // TAB_SWITCH, ESCAPE_FULLSCREEN, MINIMIZE
  details    String?   @db.Text
  timestamp  DateTime  @default(now())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  attempt    ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
