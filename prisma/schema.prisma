model LiveSession {
  id              String            @id @default(uuid()) @db.Uuid
  courseId        String            @db.Uuid
  teacherId       String            @db.Uuid
  title           String
  description     String?           @db.Text
  status          String            @default("WAITING") // WAITING, LIVE, ENDED
  countdownEnd    DateTime?
  startedAt       DateTime          @default(now())
  endedAt         DateTime?
  recordingUrl    String?
  
  course          Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher         User              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  participants    LiveParticipant[]
  attendance      LiveAttendance[]
  polls           LivePoll[]
  chatMessages    LiveChatMessage[]
  recordings      LiveRecording[]
  raisedHands     LiveRaisedHand[]
  reactions       LiveReaction[]

  @@map("live_sessions")
}

model LiveParticipant {
  id              String            @id @default(uuid()) @db.Uuid
  sessionId       String            @db.Uuid
  userId          String            @db.Uuid
  socketId        String
  joinedAt        DateTime          @default(now())
  leftAt          DateTime?
  isAdmitted      Boolean           @default(false)
  isRejected      Boolean           @default(false)
  
  session         LiveSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("live_participants")
}

model LiveAttendance {
  id              String            @id @default(uuid()) @db.Uuid
  sessionId       String            @db.Uuid
  studentId       String            @db.Uuid
  joinTime        DateTime          @default(now())
  leaveTime       DateTime?
  duration        Int               @default(0) // seconds
  reconnectCount  Int               @default(0)
  attendancePct   Decimal           @default(0.00) @db.Decimal(5, 2)
  
  session         LiveSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student         User              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("live_attendances")
}

model LivePoll {
  id              String            @id @default(uuid()) @db.Uuid
  sessionId       String            @db.Uuid
  question        String
  options         String            // JSON serialized array of options
  results         String            // JSON serialized dictionary of votes
  status          String            @default("ACTIVE") // ACTIVE, CLOSED
  created_at      DateTime          @default(now())
  
  session         LiveSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("live_polls")
}

model LiveChatMessage {
  id              String            @id @default(uuid()) @db.Uuid
  sessionId       String            @db.Uuid
  userId          String            @db.Uuid
  userName        String
  message         String            @db.Text
  created_at      DateTime          @default(now())
  
  session         LiveSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("live_chat_messages")
}

model LiveRaisedHand {
  id              String            @id @default(uuid()) @db.Uuid
  sessionId       String            @db.Uuid
  studentId       String            @db.Uuid
  raisedAt        DateTime          @default(now())
  isHandled       Boolean           @default(false)
  
  session         LiveSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student         User              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("live_raised_hands")
}

model LiveReaction {
  id              String            @id @default(uuid()) @db.Uuid
  sessionId       String            @db.Uuid
  studentId       String            @db.Uuid
  type            String            // like, heart, clap
  created_at      DateTime          @default(now())
  
  session         LiveSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student         User              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("live_reactions")
}

model LiveRecording {
  id              String            @id @default(uuid()) @db.Uuid
  sessionId       String            @db.Uuid
  streamId        String
  teacherId       String            @db.Uuid
  courseId        String            @db.Uuid
  startedAt       DateTime          @default(now())
  endedAt         DateTime?
  recordingStatus String            @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  videoId         String?           // Bunny video reference
  
  session         LiveSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("live_recordings")
}

model Message {
  id         String             @id @default(uuid()) @db.Uuid
  senderId   String             @db.Uuid
  title      String
  content    String             @db.Text
  type       String             // ANNOUNCEMENT, WARNING, NORMAL, SYSTEM
  created_at DateTime           @default(now())
  
  sender     User               @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipients MessageRecipient[]

  @@map("messages")
}

model MessageRecipient {
  id          String    @id @default(uuid()) @db.Uuid
  messageId   String    @db.Uuid
  recipientId String    @db.Uuid
  isRead      Boolean   @default(false)
  isArchived  Boolean   @default(false)
  readAt      DateTime?
  archivedAt  DateTime?

  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient   User      @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([recipientId])
  @@map("message_recipients")
}

